    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@revenuecat/purchases-capacitor": "^12.2.2",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^20.4.1",
