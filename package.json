    "content:process:existing": "node scripts/process-existing-backlog.mjs",
    "content:sync": "node scripts/content-system.mjs",
    "content:validate": "node scripts/content-validate-youtube.mjs",
    "content:queue": "node scripts/content-system.mjs",
    "content:triage": "node scripts/content-triage.mjs",
    "transcripts:translate:openai": "node scripts/translate-transcripts-openai.mjs",
