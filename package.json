{
  "name": "studyeng",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "cf:build": "npx -y @opennextjs/cloudflare@1.17.1 build",
    "cf:preview": "npm run cf:build && npx -y @opennextjs/cloudflare@1.17.1 preview",
    "cf:deploy": "npm run cf:build && npx -y @opennextjs/cloudflare@1.17.1 deploy",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "content:autodetect": "node scripts/content-autodetect.mjs",
    "content:ingest": "node scripts/content-autodetect.mjs --ingest",
