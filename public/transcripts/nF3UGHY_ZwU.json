[
  {
    "start": 0,
    "end": 1.02,
    "en": "What are you doing?",
    "ko": "뭐 하는 거야?"
  },
  {
    "start": 1.62,
    "end": 2.46,
    "en": "I can't tell you.",
    "ko": "말 못 해."
  },
  {
    "start": 2.68,
    "end": 3.12,
    "en": "You have to tell me.",
    "ko": "말해야지."
  },
  {
    "start": 3.12,
    "end": 4.56,
    "en": "I don't have to tell you anything.",
    "ko": "너한테 아무것도 말 안 해도 돼."
  },
  {
    "start": 4.64,
    "end": 8.92,
    "en": "Look, Michael, I know you don't want to have to think about this,",
    "ko": "Michael, 이걸 생각하고 싶지 않은 거 알지만,"
  },
  {
    "start": 8.98,
    "end": 11.04,
    "en": "but if something were to happen to you, God forbid,",
    "ko": "만약 무슨 일이 생기면, 절대 아니겠지만,"
  },
  {
    "start": 11.3,
    "end": 13.26,
    "en": "then I would need to know in order to take over.",
    "ko": "내가 인수하려면 알아야 해."
  },
  {
    "start": 13.36,
    "end": 15.1,
    "en": "Dwight, nothing is going to happen to me, okay?",
    "ko": "Dwight, 나한테 아무 일도 안 생겨, 알겠어?"
  },
  {
    "start": 15.1,
    "end": 16.18,
    "en": "I'm in the best shape of my life.",
    "ko": "나 인생 최고의 컨디션이야."
  },
  {
    "start": 16.38,
    "end": 16.8,
    "en": "Look at this.",
    "ko": "이거 봐."
  },
  {
    "start": 17.32,
    "end": 18.42,
    "en": "Yeah, but that doesn't matter.",
    "ko": "그래도 상관없어."
  },
  {
    "start": 18.58,
    "end": 19.66,
    "en": "You step on a mine, choke.",
    "ko": "지뢰 밟거나, 질식하거나."
  },
  {
    "start": 19.8,
    "end": 22.4,
    "en": "Okay, if I step on a mine in Scranton, Pennsylvania,",
    "ko": "Scranton, Pennsylvania에서 지뢰 밟고 죽으면"
  },
  {
    "start": 22.48,
    "end": 24.08,
    "en": "and die, you can have my job, okay?",
    "ko": "내 자리 줄 테니까, 알겠지?"
  },
  {
    "start": 24.42,
    "end": 26,
    "en": "Why don't you just go away?",
    "ko": "저리 가면 안 돼?"
  },
  {
    "start": 26,
    "end": 26.54,
    "en": "Oh, yeah.",
    "ko": "아, 그래."
  },
  {
    "start": 28.68,
    "end": 30.12,
    "en": "Keep going. You're fine.",
    "ko": "계속 가. 괜찮아."
  },
  {
    "start": 31.42,
    "end": 32.88,
    "en": "Just some bushes and some thickets.",
    "ko": "그냥 덤불이랑 관목이야."
  }
]
