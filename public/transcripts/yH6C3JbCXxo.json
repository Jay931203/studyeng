[
  {
    "start": 0,
    "end": 1.7,
    "en": "Papa, why do I feel like this?",
    "ko": "아빠, 왜 이런 기분이에요?"
  },
  {
    "start": 1.7,
    "end": 3.8,
    "en": "What's happening? You have a cold, son.",
    "ko": "무슨 일이에요? 감기 걸린 거야, 아들아."
  },
  {
    "start": 3.8,
    "end": 5.36,
    "en": "I don't think I understand.",
    "ko": "이해가 안 되는 것 같아요."
  },
  {
    "start": 7.6,
    "end": 9.4,
    "en": "What was that? A cough. A cough?",
    "ko": "그게 뭐였죠? 기침이야. 기침이요?"
  },
  {
    "start": 9.4,
    "end": 11.4,
    "en": "But coughs are for the impoverished.",
    "ko": "하지만 기침은 가난한 사람들이나 하는 건데."
  },
  {
    "start": 13.52,
    "end": 16.32,
    "en": "Are we poor, Papa? No, son, we're quite wealthy.",
    "ko": "우리 가난한 거예요, 아빠? 아니, 아들아, 우리는 꽤 부유해."
  },
  {
    "start": 16.32,
    "end": 19.48,
    "en": "Then why do I have the plague like them paws?",
    "ko": "그럼 왜 저 거지들처럼 역병에 걸린 거예요?"
  },
  {
    "start": 19.48,
    "end": 20.32,
    "en": "It's a cold.",
    "ko": "감기라니까."
  },
  {
    "start": 20.32,
    "end": 22.7,
    "en": "Or perhaps it's leprosy. I can't see my lower body.",
    "ko": "아니면 나병인가. 하반신이 안 보여요."
  },
  {
    "start": 22.7,
    "end": 23.7,
    "en": "Did it fall off, Papa?",
    "ko": "떨어져 나간 거예요, 아빠?"
  },
  {
    "start": 23.7,
    "end": 24.96,
    "en": "Check under your blanket, son.",
    "ko": "이불 밑을 확인해 봐, 아들아."
  },
  {
    "start": 26,
    "end": 27.42,
    "en": "Oh, it's still there.",
    "ko": "아, 아직 있네요."
  },
  {
    "start": 27.42,
    "end": 29.04,
    "en": "Must be the plague then.",
    "ko": "그럼 역병인가 봐요."
  },
  {
    "start": 29.04,
    "end": 30.6,
    "en": "It's happening, Papa.",
    "ko": "시작됐어요, 아빠."
  },
  {
    "start": 30.6,
    "end": 32.6,
    "en": "I can see the light. You do?",
    "ko": "빛이 보여요. 정말?"
  },
  {
    "start": 32.64,
    "end": 35.52,
    "en": "Yes, it's a red light at the bottom of a staircase. Ha, that's more like it.",
    "ko": "네, 계단 아래에 빨간 빛이요. 하, 그게 더 어울리지."
  },
  {
    "start": 36.08,
    "end": 38.14,
    "en": "Hello, Satan. What the?",
    "ko": "안녕하세요, 사탄님. 뭐?"
  },
  {
    "start": 38.14,
    "end": 39.84,
    "en": "I've missed you, Father.",
    "ko": "보고 싶었어요, 아버지."
  },
  {
    "start": 40.56,
    "end": 43.35,
    "en": "Are you talking to me, son? Shut up for a second or forever.",
    "ko": "나한테 말하는 거야, 아들아?"
  },
  {
    "start": 43.35,
    "end": 44,
    "en": "I don't care.",
    "ko": "잠깐이든 영원히든 좀 닥쳐요. 상관없어요."
  },
  {
    "start": 44,
    "end": 45.76,
    "en": "Has my time come?",
    "ko": "제 때가 온 건가요?"
  },
  {
    "start": 46.64,
    "end": 48.64,
    "en": "I see. Not yet.",
    "ko": "그렇군요. 아직 아니래요."
  },
  {
    "start": 48.64,
    "end": 50.24,
    "en": "Bye-bye, Satana.",
    "ko": "안녕, 사탄님."
  },
  {
    "start": 52.72,
    "end": 53.92,
    "en": "I want soup, Papa!",
    "ko": "수프 먹고 싶어요, 아빠!"
  }
]
