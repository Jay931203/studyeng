[
  {
    "start": 14,
    "end": 17,
    "en": "started with radio. Aw.",
    "ko": "라디오에서 시작했지. 아."
  },
  {
    "start": 17,
    "end": 19,
    "en": "Am I boring you with my compliments?",
    "ko": "내 칭찬이 지루한 거야?"
  },
  {
    "start": 19,
    "end": 21,
    "en": "Perhaps.",
    "ko": "아마도."
  },
  {
    "start": 21,
    "end": 23,
    "en": "Well, look, I'll just get to the point.",
    "ko": "그래, 본론으로 들어갈게."
  },
  {
    "start": 23,
    "end": 26,
    "en": "We've been close for a few years now, right? I mean, people know us.",
    "ko": "우리 몇 년째 가까운 사이잖아? 사람들이 우릴 알고."
  },
  {
    "start": 26,
    "end": 28,
    "en": "They love us.",
    "ko": "우릴 좋아하고."
  },
  {
    "start": 28,
    "end": 30,
    "en": "And with new overlords popping up every day.",
    "ko": "그리고 매일 새로운 지배자들이 나타나고 있잖아."
  },
  {
    "start": 30,
    "end": 34,
    "en": "And before you hit me with it... Well, you offered it to yourself. I know, okay?",
    "ko": "네가 그 얘기 꺼내기 전에... 네가 스스로 제안한 거잖아. 알아, 알겠어?"
  },
  {
    "start": 34,
    "end": 36,
    "en": "But I'm much more forward-thinking,",
    "ko": "하지만 나는 훨씬 더 앞을 내다보는 사람이니까"
  },
  {
    "start": 36,
    "end": 38,
    "en": "so it's in your best interest to hear me out.",
    "ko": "내 말을 듣는 게 네게 이익이야."
  },
  {
    "start": 38,
    "end": 40,
    "en": "I'm listening, pal.",
    "ko": "듣고 있어, 친구."
  },
  {
    "start": 40,
    "end": 42,
    "en": "Barkeep, another whiskey?",
    "ko": "바텐더, 위스키 한 잔 더?"
  },
  {
    "start": 44,
    "end": 48,
    "en": "So, I've been thinking, Alistair,",
    "ko": "그래서 생각해 봤는데, 앨리스테어"
  },
  {
    "start": 48,
    "end": 50,
    "en": "with your incredible power",
    "ko": "네 엄청난 힘과"
  },
  {
    "start": 50,
    "end": 53,
    "en": "and my massive influence,",
    "ko": "나의 막대한 영향력이 합쳐지면"
  },
  {
    "start": 53,
    "end": 55,
    "en": "we would be unstoppable.",
    "ko": "우리를 막을 수 없을 거야."
  },
  {
    "start": 55,
    "end": 58,
    "en": "Radio and video. Me and you.",
    "ko": "라디오와 비디오. 너와 나."
  },
  {
    "start": 58,
    "end": 61,
    "en": "We could rule hell. Together.",
    "ko": "우리가 지옥을 지배할 수 있어. 함께."
  },
  {
    "start": 61,
    "end": 63,
    "en": "As partners.",
    "ko": "파트너로서."
  },
  {
    "start": 63,
    "end": 65,
    "en": "Uh-huh. Uh-huh.",
    "ko": "으흠. 으흠."
  },
  {
    "start": 65,
    "end": 68,
    "en": "Ah-ha-ha-ha-ha-ha-ha-ha-ha-ha-ha!",
    "ko": "아하하하하하하하하하!"
  },
  {
    "start": 68,
    "end": 70,
    "en": "Oh, that's...",
    "ko": "아, 그건..."
  },
  {
    "start": 70,
    "end": 72,
    "en": "Oh, you're serious!",
    "ko": "아, 진심이었어!"
  },
  {
    "start": 72,
    "end": 75,
    "en": "Oh, come now, Vox!",
    "ko": "이봐, 복스!"
  }
]
