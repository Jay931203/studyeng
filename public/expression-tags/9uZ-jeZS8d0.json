      "ko": "예를 들어, 하나를 반으로 자르면,",
      "tags": {
        "functions": [],
        "situation": "",
        "cefr": "",
        "register": "",
        "emotions": [],
        "expression_types": [],
        "vibe": "",
        "power": [],
        "grammar_intent": [],
        "flags": []
      }
    },
    {
