        "power": [],
        "grammar_intent": [],
        "flags": []
      }
    },
    {
      "id": "9uZ-jeZS8d0-4",
      "en": "and if you make even a small mistake in counting off 45 seconds,",
      "ko": "45초를 세는 데 작은 실수라도 하면,",
      "tags": {
        "functions": [],
        "situation": "",
        "cefr": "",
        "register": "",
        "emotions": [],
        "expression_types": [],
        "vibe": "",
        "power": [],
        "grammar_intent": [],
        "flags": []
      }
    },
    {
