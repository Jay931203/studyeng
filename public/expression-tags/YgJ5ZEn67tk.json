        "vibe": "",
        "power": [],
        "grammar_intent": [],
        "flags": []
      }
    },
    {
      "id": "YgJ5ZEn67tk-6",
      "en": "This... This isn't the Matrix. No.",
      "ko": "이건... 이건 매트릭스가 아니야. 아니.",
