      "ko": "도전이 커질수록 뇌의 신호도 커지고,",
      "tags": {
        "functions": [],
        "situation": "",
        "cefr": "",
        "register": "",
        "emotions": [],
        "expression_types": [],
        "vibe": "",
        "power": [],
        "grammar_intent": [],
        "flags": []
      }
    },
    {
