      "ko": "이것은 아이리스를 촉촉하게 유지하고, 침입하는 세균을 막아주며,",
      "tags": {
        "functions": [],
        "situation": "",
        "cefr": "",
        "register": "",
        "emotions": [],
        "expression_types": [],
        "vibe": "",
        "power": [],
        "grammar_intent": [],
        "flags": []
