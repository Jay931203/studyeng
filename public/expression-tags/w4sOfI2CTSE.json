        "emotions": [],
        "expression_types": [],
        "vibe": "",
        "power": [],
        "grammar_intent": [],
        "flags": []
      }
    },
    {
      "id": "w4sOfI2CTSE-6",
      "en": "It's the custom, not the law.",
      "ko": "관습이지, 법은 아니야.",
