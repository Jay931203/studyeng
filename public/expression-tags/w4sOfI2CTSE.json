        "vibe": "",
        "power": [],
        "grammar_intent": [],
        "flags": []
      }
    },
    {
      "id": "w4sOfI2CTSE-4",
      "en": "I think you'll find it's very much their business.",
      "ko": "그들에게는 매우 중요한 일일 거야.",
      "tags": {
        "functions": [],
        "situation": "",
