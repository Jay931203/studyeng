{
  "name": "studyeng",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "studyeng"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "logs": {
      "enabled": true
    }
  }
}
