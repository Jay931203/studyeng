# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/.open-next/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
.dev.vars*
!.dev.vars.example

# vercel
.vercel
/.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# whisper raw responses (large, local backup only)
/logs/whisper-raw/
/logs/
/docs/.pdca-snapshots/

# local expression extraction intermediates / scratch scripts
/scripts/expr-chunk-*.json
/scripts/expr-result-*.json
/scripts/expr-dict-progress.json
/scripts/expr-tagged-sentences.json
/scripts/check-chunk.mjs
/scripts/extract-expr-1.cjs
/scripts/extract-expressions.mjs
/scripts/extract-expressions-2.mjs
/scripts/fix-komisalign-batch1.mjs
/scripts/fullcheck-batch2.mjs
/scripts/retag-batch2.mjs
/scripts/tag-batch1.mjs

# local Codex / Playwright artifacts
.codex-next-dev*.log
.playwright-cli/
tmp-vercel-inspect.json
/output/playwright/
